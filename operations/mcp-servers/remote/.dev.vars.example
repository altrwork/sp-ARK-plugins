# Local development secrets for `wrangler dev`.
# Copy to `.dev.vars` (gitignored) and fill in. In production these are set with
# `wrangler secret put <NAME>` instead.

# GitHub OAuth app (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Random 32+ char string. Generate with: openssl rand -hex 32
COOKIE_ENCRYPTION_KEY=

# Upstream API credentials
BOSSHUB_ACCESS_TOKEN=
VERKADA_API_KEY=
NEXUDUS_ACCESS_TOKEN=

# Microsoft Graph (Outlook drafts)
# Register an Entra app: https://entra.microsoft.com → App registrations
# Grant application permission: Mail.ReadWrite (requires admin consent)
# MS_TENANT_ID, MS_CLIENT_ID, MS_SENDER_EMAIL also go in wrangler.jsonc vars
MS_CLIENT_SECRET=
