{
  "mcpServers": {
    "ms365": {
      "command": "npx",
      "args": ["-y", "@softeria/ms-365-mcp-server", "--org-mode"],
      "env": {
        "MS365_MCP_OUTPUT_FORMAT": "toon"
      }
    },
    "bosshub": {
      "command": "sh",
      "args": ["-c", "[ -d mcp-servers/bosshub/node_modules ] || npm --prefix mcp-servers/bosshub ci --silent; node mcp-servers/bosshub/src/index.js"],
      "env": {
        "BOSSHUB_ACCESS_TOKEN": "${BOSSHUB_ACCESS_TOKEN}",
        "BOSSHUB_LOCATION_ID": "jqh6rxfWtvMIQCKxcDlc",
        "BOSSHUB_FORM_ID": "Ftg5p93SEeTnUWiyAgYn",
        "BOSSHUB_API_VERSION": "2023-02-21"
      }
    },
    "verkada": {
      "command": "sh",
      "args": ["-c", "[ -d mcp-servers/verkada/node_modules ] || npm --prefix mcp-servers/verkada ci --silent; node mcp-servers/verkada/src/index.js"],
      "env": {
        "VERKADA_API_KEY": "${VERKADA_API_KEY}",
        "VERKADA_REGION": "api",
        "VERKADA_DRY_RUN": "false"
      }
    },
    "nexudus": {
      "command": "sh",
      "args": ["-c", "[ -d mcp-servers/nexudus/node_modules ] || npm --prefix mcp-servers/nexudus ci --silent; node mcp-servers/nexudus/src/index.js"],
      "env": {
        "NEXUDUS_USERNAME": "${NEXUDUS_USERNAME}",
        "NEXUDUS_PASSWORD": "${NEXUDUS_PASSWORD}",
        "NEXUDUS_BUSINESS_ID": "${NEXUDUS_BUSINESS_ID}",
        "NEXUDUS_DRY_RUN": "false"
      }
    }
  }
}
